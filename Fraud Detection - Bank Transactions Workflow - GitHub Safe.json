    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"llama-3.1-8b-instant\", messages: [{ role: \"system\", content: \"You are a fraud analyst at a bank. Analyze flagged transactions and respond ONLY in JSON with keys: ai_score (1-100), ai_risk_level (LOW/MEDIUM/HIGH/CRITICAL), explanation (2 sentences max), recommendation (one clear action). No extra text.\" }, { role: \"user\", content: \"Analyze this flagged transaction:\\nAccount: \" + $json.account_number + \"\\nAmount: \u20b9\" + $json.amount + \"\\nAvg Transaction: \u20b9\" + $json.avg_transaction_amount + \"\\nDeviation: \" + $json.deviation_multiple + \"x\\nLocation: \" + $json.location + \"\\nKnown Locations: \" + $json.known_locations + \"\\nDevice: \" + $json.device_id + \"\\nKnown Devices: \" + $json.known_devices + \"\\nTime: \" + $json.timestamp + \"\\nRule Score: \" + $json.rule_score + \"/100\\nFlags: \" + $json.flags + \"\\nAccount Age: \" + $json.account_age_days + \" days\" }] }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        -272,
        -16
      ],
      "id": "25f484bb-75a3-4906-ba56-0d540973737b",
      "name": "Groq AI Fraud Analyzer"
    },
    {
      "parameters": {
        "jsCode": "const groqRaw = $input.first().json.choices[0].message.content;\nconst prev = $('Rule Engine + Deviation Scorer').item.json;\n\nlet aiResult;\ntry {\n  const cleaned = groqRaw.replace(/```json|```/g, '').trim();\n  aiResult = JSON.parse(cleaned);\n} catch(e) {\n  aiResult = {\n    ai_score: 0,\n    ai_risk_level: 'UNKNOWN',\n    explanation: groqRaw,\n    recommendation: 'Manual review required'\n  };\n}\n\nreturn [{\n  json: {\n    account_number: prev.account_number,\n    amount: prev.amount,\n    transaction_type: prev.transaction_type,\n    location: prev.location,\n    device_id: prev.device_id,\n    timestamp: prev.timestamp,\n    avg_transaction_amount: prev.avg_transaction_amount,\n    deviation_multiple: prev.deviation_multiple,\n    rule_score: prev.rule_score,\n    risk_level: prev.risk_level,\n    flags: prev.flags,\n    ai_score: aiResult.ai_score,\n    ai_risk_level: aiResult.ai_risk_level,\n    explanation: aiResult.explanation,\n    recommendation: aiResult.recommendation\n  }\n}];"
      },
