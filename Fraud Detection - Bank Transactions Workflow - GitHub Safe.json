    {
      "parameters": {
        "jsCode": "const accountNumber = $('Transaction Webhook').item.json.body.account_number;\nconst allRows = $input.all();\n\nconst matchedRow = allRows.find(row => row.json.account_number === accountNumber);\n\nif (!matchedRow) {\n  throw new Error(`Account ${accountNumber} not found in Account History`);\n}\n\nreturn [{\n  json: {\n    ...$('Transaction Webhook').item.json.body,\n    avg_transaction_amount: matchedRow.json.avg_transaction_amount,\n    known_locations: matchedRow.json.known_locations,\n    known_devices: matchedRow.json.known_devices,\n    account_age_days: matchedRow.json.account_age_days\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        -16
      ],
      "id": "991732a2-e683-4248-8f8d-8e40760d1af0",
      "name": "Account Matcher"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nlet score = 0;\nlet flags = [];\n\nconst amount = Number(data.amount);\nconst avgAmount = Number(data.avg_transaction_amount);\nconst accountAge = Number(data.account_age_days);\n\n// 1. Fixed rule: Large amount\nif (amount > 200000) { score += 30; flags.push('Large amount (>\u20b92,00,000)'); }\nelse if (amount > 50000) { score += 15; flags.push('Moderate-large amount (\u20b950k-2L)'); }\n\n// 2. Odd hour check\nconst hour = new Date(data.timestamp).getHours();\nif (hour >= 0 && hour < 5) { score += 20; flags.push('Transaction during odd hours (12AM-5AM)'); }\n\n// 3. New account check\nif (accountAge < 30) { score += 20; flags.push('New account (<30 days old)'); }\n\n// 4. Unknown location check\nconst knownLocations = (data.known_locations || '').split(',').map(l => l.trim());\nif (!knownLocations.includes(data.location)) {\n  score += 15;\n  flags.push(`Unknown location: ${data.location}`);\n}\n\n// 5. Unknown device check\nconst knownDevices = (data.known_devices || '').split(',').map(d => d.trim());\nif (!knownDevices.includes(data.device_id)) {\n  score += 15;\n  flags.push(`Unknown device: ${data.device_id}`);\n}\n\n// 6. Behavioral deviation - compare against account's own average\nlet deviationMultiple = 0;\nif (avgAmount > 0) {\n  deviationMultiple = amount / avgAmount;\n  if (deviationMultiple >= 10) { score += 25; flags.push(`Extreme deviation: ${deviationMultiple.toFixed(1)}x account's average`); }\n  else if (deviationMultiple >= 5) { score += 15; flags.push(`High deviation: ${deviationMultiple.toFixed(1)}x account's average`); }\n  else if (deviationMultiple >= 3) { score += 8; flags.push(`Moderate deviation: ${deviationMultiple.toFixed(1)}x account's average`); }\n}\n\n// Classification\nlet riskLevel = '';\nif (score >= 70) riskLevel = 'CRITICAL';\nelse if (score >= 50) riskLevel = 'HIGH';\nelse if (score >= 30) riskLevel = 'MEDIUM';\nelse riskLevel = 'LOW';\n\nreturn [{\n  json: {\n    ...data,\n    rule_score: score,\n    risk_level: riskLevel,\n    flags: flags.join('; '),\n    deviation_multiple: deviationMultiple.toFixed(1)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -464,
